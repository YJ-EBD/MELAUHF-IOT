server { ... } 블록 안에 이걸 추가해:
# 절대 노출 금지 파일/경로 차단 (.env, git, 설정파일 등)
location ~* (^|/)\.(env|git|svn|htaccess|htpasswd) {
    deny all;
    return 404;
}

location ~* \.(bak|old|swp|sql|zip|tar|gz|7z)$ {
    deny all;
    return 404;
}

# Laravel/Node/기타 프레임워크에서 자주 노리는 경로
location ~* ^/(vendor|storage|bootstrap|config|database|resources|routes|app)/ {
    deny all;
    return 404;
}

저장 후 적용:
sudo nginx -t
sudo systemctl reload nginx


